DATABASE_URL=postgresql://identity:identity@identity-data:5432/identity?schema=public
AUTH_SECRET=change-me-super-secret
NEXTAUTH_SECRET=change-me-super-secret
NEXTAUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000

GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

MINIO_ENDPOINT=identity-storage
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_UPLOADS=identity-uploads
MINIO_BUCKET_GENERATIONS=identity-generations

FACEFUSION_IMAGE=facefusion/facefusion:3.6.0-cpu
FACEFUSION_CONTAINER_NAME=identity-face
FACEFUSION_SHARED_DATA_PATH=/data
FACEFUSION_EXECUTION_PROVIDERS=cpu
FACEFUSION_EXECUTION_THREAD_COUNT=4
FACEFUSION_OUTPUT_IMAGE_QUALITY=90
FACEFUSION_PROCESSORS_FAITHFUL=face_swapper
FACEFUSION_PROCESSORS_EDITORIAL=face_swapper face_enhancer
FACEFUSION_PROCESSORS_CINEMATIC=face_swapper face_enhancer frame_enhancer
FACEFUSION_COMMAND_TIMEOUT_MS=900000
FACEFUSION_KEEP_ARTIFACTS=false

JOB_MAX_ATTEMPTS=8
JOB_ANALYSIS_MAX_ATTEMPTS=5
JOB_GENERATION_MAX_ATTEMPTS=10
WORKER_POLL_INTERVAL_MS=3000
WORKER_HEALTH_PORT=3001
WORKER_ID=identity-worker
IDENTITY_MIN_VALID_IMAGES=4
IDENTITY_CLUSTER_SIMILARITY_THRESHOLD=0.82
IDENTITY_VALIDITY_SIMILARITY_THRESHOLD=70
GENERATION_IDENTITY_SIMILARITY_MIN=75
GENERATION_REFERENCE_COMPOSITION_MIN=70
GENERATION_BACKGROUND_PRESERVATION_MIN=65
GENERATION_POSE_MATCH_MIN=70
GENERATION_OVERALL_ACCEPTANCE_MIN=74
GENERATION_STRICT_MODERATION=false
GENERATION_VARIANT_MAX_RETRIES=4
